generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Topic {
  id          Int      @id @default(autoincrement())
  title       String   @unique
  description String?
  createdAt   DateTime @default(now())

  domain     String?
  difficulty Int?
  isCore     Boolean @default(false)

  sourceRelations Relation[] @relation("SourceTopic")
  targetRelations Relation[] @relation("TargetTopic")
}

model Relation {
  id Int @id @default(autoincrement())

  sourceId Int
  targetId Int

  type RelationType @default(NECESSARY)

  source Topic @relation("SourceTopic", fields: [sourceId], references: [id])
  target Topic @relation("TargetTopic", fields: [targetId], references: [id])
}

enum RelationType {
  NECESSARY
  RECOMMENDED
  RELATED
}
